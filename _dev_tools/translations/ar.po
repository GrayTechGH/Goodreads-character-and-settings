msgstr "حول"

msgid "About Goodreads character and settings"
msgstr "حول شخصيات وأماكن Goodreads"

msgid "Plugin that imports character and settings data from Goodreads and writes it to custom fields"
msgstr "Plugin that imports character and settings data from Goodreads and writes it to custom fields"
