msgid "Use the selected-language country names as country values. The selected-language names are also kept as aliases."
msgstr "Usar los nombres de países del idioma seleccionado como valores de país. También se conservan como alias."

msgid "Keep country in settings field"
msgstr "Conservar el país en el campo de lugares"

msgid "Keep the country in parentheses in the Settings field while also writing it to the Countries field."
msgstr "Conservar el país entre paréntesis en el campo de lugares y escribirlo también en el campo de países."

msgid "Keep region in settings field"
msgstr "Conservar la región en el campo de lugares"

msgid "Keep region or subdivision values such as states, provinces, and countries-in-Regions mappings in the Settings field."
msgstr "Conservar en el campo de lugares las regiones o subdivisiones como estados, provincias y países asignados en Regiones."

msgid "Write \"Empty\" when Goodreads has no value"
msgstr "Escribir \"Empty\" cuando Goodreads no tenga valor"

