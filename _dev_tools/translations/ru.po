msgstr "Локализовать названия стран"

msgid "Use the selected-language country names as country values. The selected-language names are also kept as aliases."
msgstr "Использовать названия стран на выбранном языке как значения стран. Эти названия также сохраняются как псевдонимы."

msgid "Keep country in settings field"
msgstr "Сохранять страну в поле мест"

msgid "Keep the country in parentheses in the Settings field while also writing it to the Countries field."
msgstr "Сохранять страну в скобках в поле мест и также записывать ее в поле стран."

msgid "Keep region in settings field"
msgstr "Сохранять регион в поле мест"

msgid "Keep region or subdivision values such as states, provinces, and countries-in-Regions mappings in the Settings field."
msgstr "Сохранять в поле мест регионы или подразделения, такие как штаты, провинции и страны, сопоставленные в регионах."

